{
  "name": "tailgraph",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "dev:frontend": "vite --config vite.config.ts",
    "dev:backend": ".venv/bin/python -m uvicorn backend.app:create_app --factory --reload --host 0.0.0.0 --port 8081",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 reload ecosystem.config.cjs --update-env",
    "pm2:stop": "pm2 delete tailgraph-backend tailgraph-frontend",
    "pm2:logs": "pm2 logs",
    "build": "tsc --noEmit && vite build --config vite.config.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^24.1.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.14",
    "vitest": "^2.1.9"
  }
}
